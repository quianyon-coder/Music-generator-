# Flask Configuration
FLASK_ENV=development
FLASK_APP=run.py
DEBUG=True

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/music_generator
SQLALCHEMY_TRACK_MODIFICATIONS=False

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600

# File Upload
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=52428800
ALLOWED_EXTENSIONS=wav,mp3,flac

# Audio Generation
DEFAULT_SAMPLE_RATE=44100
DEFAULT_DURATION=30
DEFAULT_TEMPO=120

# API Configuration
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# Music Generation Parameters
MIN_TEMPO=60
MAX_TEMPO=200
SUPPORTED_INSTRUMENTS=piano,violin,flute,guitar,synth,drums,bass,trumpet
SUPPORTED_MOODS=happy,sad,energetic,calm,mysterious,romantic,dramatic

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
